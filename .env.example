# Supabase Configuration
# Get these values from your Supabase project settings
# Dashboard -> Project Settings -> API
#
# IMPORTANT: Use separate Supabase projects for staging and production.
# See docs/plans/ENVIRONMENT_SETUP.md for full environment separation guide.
#
# - Production:  https://yourdomain.com           → prod Supabase project
# - Staging:     https://staging.yourdomain.com   → staging Supabase project
# - Development: http://localhost:5173             → staging Supabase project (shared)

# Your Supabase project URL
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous (public) key - safe to use in browser
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# (Optional) Service role key - only use server-side, never expose to browser
# Only needed for admin operations or server-side API routes
# Prefix with PUBLIC_ is intentionally omitted — this key must stay server-side only
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Buy Me a Coffee integration
# Set to your buymeacoffee.com profile URL to enable the floating button
# Example: https://buymeacoffee.com/yourusername
# Leave empty or omit in staging/preview environments
PUBLIC_BMC_URL=https://buymeacoffee.com/xsaardo

# Rate Limiting
# Set to 'true' in test environments to disable rate limiting (prevents e2e test throttling)
# DISABLE_RATE_LIMITING=true
